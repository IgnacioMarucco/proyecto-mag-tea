DB_NAME=magtea
DB_USERNAME=postgres
DB_PASSWORD=postgres
JWT_SECRET=reemplazar-con-secreto-seguro-minimo-256-bits
ADMIN_EMAIL=admin@magtea.com
ADMIN_PASSWORD=reemplazar-con-password-seguro
SEED_INVESTIGADOR_EMAIL=investigador@magtea.com
SEED_INVESTIGADOR_PASSWORD=reemplazar-con-password-seguro
SEED_MEDICO_EMAIL=medico@magtea.com
SEED_MEDICO_PASSWORD=reemplazar-con-password-seguro
SEED_TECNICO_EMAIL=tecnico@magtea.com
SEED_TECNICO_PASSWORD=reemplazar-con-password-seguro
MAIL_USERNAME=ignaciomarucco@gmail.com
MAIL_PASSWORD=reemplazar-con-app-password-de-gmail
APP_BASE_URL=http://localhost:4200
# Mercado Pago — Checkout Pro
MP_ACCESS_TOKEN=
# URL base del frontend para redirección post-pago (en dev con ngrok: poner la URL de ngrok)
MP_BACK_URL_BASE=http://localhost:4200
# URL pública del webhook (vacío en dev — usar ngrok http 8080 para testear)
MP_NOTIFICATION_URL=
# CORS — orígenes permitidos, separados por coma
# En dev con ngrok: agregar la URL de ngrok separada por coma
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://app.localhost:4200
# Perfil de Spring Boot — dev en local, prod en el servidor de producción
SPRING_PROFILES_ACTIVE=dev
# MinIO — object storage para documentos y fotos de microscopía
# En dev se genera automáticamente con docker compose; en prod cambiar las credenciales
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
# URL pública de MinIO accesible desde el navegador (OBLIGATORIO — no tiene valor por defecto)
# En dev: http://localhost:9000
# En prod: http://<ip-o-dominio-del-servidor>:9000 (o URL del CDN/proxy si aplica)
MINIO_PUBLIC_URL=http://localhost:9000
